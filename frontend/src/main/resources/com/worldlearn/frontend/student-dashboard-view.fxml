<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.worldlearn.frontend.StudentDashboardController"
      alignment="TOP_LEFT" spacing="10.0">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <!-- Top bar -->
    <HBox>
        <Label text="WORLD LEARN"
               style="-fx-text-fill: green; -fx-font-size: 28px; -fx-font-weight: bold;"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <!-- Hook this up if you add an onLogoutClick handler in the controller -->
        <Button text="Log Out"
                style="-fx-background-color: red; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 6;"/>
    </HBox>

    <!-- Greeting -->
    <Label fx:id="welcomeLabel"
           text="Welcome, UserNamePlaceholder!"
           style="-fx-text-fill: black; -fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="16">

        <!-- Left column with two cards -->
        <VBox spacing="16" HBox.hgrow="ALWAYS">

            <!-- Classes card -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#onClassesButtonClick"
                  style="-fx-background-color: #e9ffd9; -fx-background-radius: 20; -fx-padding: 20; -fx-cursor: hand;">
                <VBox spacing="6">
                    <Label text="Classes" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                    <Label text=""/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="image" style="-fx-font-size: 64;"/>
            </HBox>

            <!-- Profile card -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#setProfileButtonClick"
                  style="-fx-background-color: #e9ffd9; -fx-background-radius: 20; -fx-padding: 20; -fx-cursor: hand;">
                <VBox spacing="6">
                    <Label text="Profile" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="image" style="-fx-font-size: 64;"/>
            </HBox>

        </VBox>

        <!-- Teacher card (right column) -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              onMouseClicked="#onTeacherButtonClick"
              style="-fx-background-color: #e9ffd9; -fx-background-radius: 20; -fx-padding: 20; -fx-cursor: hand;">
            <VBox spacing="6">
                <Label text="Teacher" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="image" style="-fx-font-size: 64;"/>
        </HBox>

        <!-- Right sidebar -->
        <VBox prefWidth="120" alignment="CENTER"
              style="-fx-background-color: #efe8f2; -fx-background-radius: 20;" VBox.vgrow="ALWAYS">
            <Label text="⚙" style="-fx-font-size: 48;"/>
        </VBox>

    </HBox>
</VBox>